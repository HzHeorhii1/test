{
  "name": "spherax",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build:iam": "nest build iam",
    "build:notify": "nest build notify",
    "start:dev:iam": "nest start iam --watch",
    "start:dev:notify": "nest start notify --watch",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config jest-e2e.json",
    "proto:gen": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=libs/proto/src/generated --ts_proto_opt=nestJs=true --ts_proto_opt=outputServices=grpc-js --proto_path=libs/proto/src/proto libs/proto/src/proto/*.proto",
    "generate:iam": "prisma generate --schema services/iam/prisma/schema.prisma",
    "generate:notify": "prisma generate --schema services/notify/prisma/schema.prisma",
    "generate:all": "npm run generate:iam && npm run generate:notify",
    "migrate:iam": "prisma migrate dev --config services/iam/prisma/prisma.config.ts",
    "migrate:notify": "prisma migrate dev --config services/notify/prisma/prisma.config.ts",
    "migrate:all": "npm run migrate:iam && npm run migrate:notify",
    "prepare": "husky",
    "format:write": "prettier --write .",
    "build": "npm run build:iam && npm run build:notify",
    "migrate:deploy:iam": "prisma migrate deploy --config services/iam/prisma/prisma.config.ts",
    "migrate:deploy:notify": "prisma migrate deploy --config services/notify/prisma/prisma.config.ts",
    "migrate:deploy:all": "npm run migrate:deploy:iam && npm run migrate:deploy:notify"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.11.0",
    "@grpc/proto-loader": "^0.7.0",
    "@nestjs-modules/mailer": "^2.3.6",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/cqrs": "^10.2.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.77.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^17.13.0",
    "nest-winston": "^1.10.0",
    "nodemailer": "^8.0.9",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "ts-proto": "^2.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "services/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/services/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "@spherax/common/(.*)": "<rootDir>/libs/common/src/$1",
      "@spherax/common": "<rootDir>/libs/common/src",
      "@spherax/proto/(.*)": "<rootDir>/libs/proto/src/$1",
      "@spherax/proto": "<rootDir>/libs/proto/src",
      "@spherax/auth/(.*)": "<rootDir>/libs/auth/src/$1",
      "@spherax/auth": "<rootDir>/libs/auth/src"
    }
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,cjs,mjs,ts}": [
      "eslint --fix"
    ]
  }
}
