# Common
NODE_ENV=development
LOG_LEVEL=debug

# IAM service
IAM_REST_PORT=3001
IAM_GRPC_PORT=5001
IAM_JWT_SECRET=change-me-in-production
IAM_JWT_EXPIRES_IN=3600

# Notify service
NOTIFY_REST_PORT=3002
NOTIFY_GRPC_PORT=5002

# gRPC — used by notify to call iam
IAM_GRPC_HOST=localhost
IAM_GRPC_PORT_INTERNAL=5001

# Databases
DATABASE_URL_IAM=postgresql://postgres:postgres@postgres:5432/iam_dev
DATABASE_URL_NOTIFY=postgresql://postgres:postgres@postgres:5432/notify_dev
