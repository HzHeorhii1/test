# Common
NODE_ENV=development
LOG_LEVEL=debug

# IAM service
IAM_REST_PORT=3001
IAM_GRPC_PORT=5001
IAM_JWT_SECRET=change-me-in-production
IAM_JWT_EXPIRES_IN=3600

# Notify service
NOTIFY_REST_PORT=3002
NOTIFY_GRPC_PORT=5002

# gRPC — used by notify to call iam
IAM_GRPC_HOST=localhost
IAM_GRPC_PORT_INTERNAL=5001

# Databases
# When running via docker-compose, use the service name as the host (db).
# For a standalone .env on the host machine (outside Docker), use localhost.
DATABASE_URL_IAM=postgresql://postgres:postgres@db:5432/iam_dev
DATABASE_URL_NOTIFY=postgresql://postgres:postgres@db:5432/notify_dev

# SMTP (Mailpit for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@spherax.local

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
