{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "services/iam",
  "sourceRoot": "services/iam/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false
  },
  "projects": {
    "iam": {
      "type": "application",
      "root": "services/iam",
      "entryFile": "main",
      "sourceRoot": "services/iam/src",
      "compilerOptions": {
        "tsConfigPath": "services/iam/tsconfig.app.json"
      }
    },
    "notify": {
      "type": "application",
      "root": "services/notify",
      "entryFile": "main",
      "sourceRoot": "services/notify/src",
      "compilerOptions": {
        "tsConfigPath": "services/notify/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "proto": {
      "type": "library",
      "root": "libs/proto",
      "entryFile": "index",
      "sourceRoot": "libs/proto/src",
      "compilerOptions": {
        "tsConfigPath": "libs/proto/tsconfig.lib.json"
      }
    },
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    }
  }
}
